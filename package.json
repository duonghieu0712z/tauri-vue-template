{
    "name": "kazmas",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "build-only": "vite build",
        "type-check": "vue-tsc --noEmit",
        "start": "pnpm tauri dev",
        "make": "pnpm tauri build",
        "lint": "run-s lint:check:*",
        "lint:fix": "run-s lint:fix:*",
        "lint:check:oxlint": "oxlint .",
        "lint:check:eslint": "eslint . --cache",
        "lint:fix:oxlint": "oxlint --fix .",
        "lint:fix:eslint": "eslint --fix . --cache",
        "format": "oxfmt --check .",
        "format:fix": "oxfmt .",
        "bump": "node bump-version.js",
        "prepare": "husky"
    },
    "dependencies": {
        "@lucide/vue": "^1.16.0",
        "@tauri-apps/api": "^2",
        "@tauri-apps/plugin-log": "~2.8.0",
        "@vueuse/core": "^14.3.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lorem-ipsum": "^3.0.0",
        "pinia": "^3.0.4",
        "reka-ui": "^2.9.7",
        "tailwind-merge": "^3.6.0",
        "vue": "^3.5.34"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.0",
        "@tauri-apps/cli": "^2.11.1",
        "@tsconfig/node24": "^24.0.4",
        "@types/node": "^25.8.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^10.4.0",
        "eslint-plugin-oxlint": "^1.65.0",
        "eslint-plugin-vue": "^10.9.1",
        "husky": "^9.1.7",
        "jiti": "^2.7.0",
        "lint-staged": "^17.0.4",
        "npm-run-all2": "^8.0.4",
        "oxfmt": "^0.46.0",
        "oxlint": "^1.61.0",
        "tailwindcss": "^4.2.2",
        "typescript": "~6.0.3",
        "vite": "^8.0.8",
        "vue-tsc": "^3.2.6"
    },
    "lint-staged": {
        "*.{ts,tsx,vue,html,css,json,yaml}": [
            "oxfmt"
        ],
        "*.{ts,tsx,vue}": [
            "oxlint --fix",
            "eslint --fix"
        ]
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    }
}
